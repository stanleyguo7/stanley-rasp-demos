{
  "name": "unified-auth",
  "version": "0.2.0",
  "private": true,
  "description": "Unified auth SDK + HTTP server for stanley-rasp-demos",
  "main": "sdk/index.js",
  "exports": {
    ".":        "./sdk/index.js",
    "./sdk":    "./sdk/index.js",
    "./client": "./client/auth-client.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev":   "AUTH_SECRET=dev-secret PORT=8787 node server.js"
  },
  "engines": {
    "node": ">=18"
  }
}
